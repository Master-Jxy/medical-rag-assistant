# 真实密钥只填写在本地 .env 中，不要提交到 Git。
DASHSCOPE_API_KEY=your_dashscope_api_key_here
CHAT_MODEL_NAME=qwen3-max
EMBEDDING_MODEL_NAME=text-embedding-v4
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=agent
UPLOAD_DIR=./data
DOCUMENT_REGISTRY_PATH=./data/documents.json
KNOWLEDGE_BASE_VERSION=live_v1
MAX_UPLOAD_SIZE_BYTES=10485760
CHUNK_SIZE=800
CHUNK_OVERLAP=100
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
DATABASE_URL=mysql+pymysql://medical_rag_user:change_me@127.0.0.1:3306/medical_rag?charset=utf8mb4
REDIS_URL=
REDIS_CONNECT_TIMEOUT_SECONDS=0.5
REDIS_SOCKET_TIMEOUT_SECONDS=0.5
AUTH_REGISTER_RATE_LIMIT=5
AUTH_REGISTER_RATE_WINDOW_SECONDS=600
AUTH_LOGIN_RATE_LIMIT=10
AUTH_LOGIN_RATE_WINDOW_SECONDS=300
CHAT_RATE_LIMIT=10
CHAT_RATE_WINDOW_SECONDS=60
UPLOAD_RATE_LIMIT=5
UPLOAD_RATE_WINDOW_SECONDS=3600
UPLOAD_CONCURRENCY_LIMIT=1
UPLOAD_CONCURRENCY_TTL_SECONDS=600
GENERATION_LOCK_TTL_SECONDS=600
IDEMPOTENCY_IN_PROGRESS_TTL_SECONDS=600
IDEMPOTENCY_RESULT_TTL_SECONDS=86400
AUTH_RATE_LIMIT_FALLBACK_MAX_KEYS=4096
TRUSTED_PROXY_IPS=[]
JWT_SECRET_KEY=replace_with_a_random_secret_at_least_32_characters_long
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
MAX_HISTORY_ROUNDS=3
MAX_HISTORY_CHARS=6000
# 默认不启用相关度阈值；启用示例：RAG_MIN_RELEVANCE_SCORE=0.70
RAG_FILTER_DEPARTMENT=
RAG_FILTER_TOPIC=
RAG_FILTER_DOCUMENT_TYPE=
RAG_FILTER_KNOWLEDGE_BASE_VERSION=
RAG_INSUFFICIENT_KNOWLEDGE_MESSAGE=知识库资料不足，无法根据现有资料回答。
RAG_HYBRID_SEARCH_ENABLED=false
RAG_HYBRID_VECTOR_WEIGHT=0.7
RAG_HYBRID_KEYWORD_WEIGHT=0.3
RAG_HYBRID_RRF_K=60
RAG_RERANK_ENABLED=false
RAG_RERANK_MODEL_NAME=gte-rerank-v2
RAG_RERANK_MAX_CANDIDATES=10
RAG_RERANK_TIMEOUT_SECONDS=3
RAG_RERANK_MAX_INPUT_TOKENS=12000
RAG_RERANK_INPUT_PRICE_PER_MILLION_TOKENS_CNY=0.8
RAG_RERANK_MAX_ESTIMATED_COST_CNY=0.01
