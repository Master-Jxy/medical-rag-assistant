{
  "$defs": {
    "BaselineCaseResult": {
      "additionalProperties": false,
      "properties": {
        "case_id": {
          "title": "Case Id",
          "type": "string"
        },
        "category": {
          "$ref": "#/$defs/EvaluationCategory"
        },
        "expected_behavior": {
          "$ref": "#/$defs/ExpectedBehavior"
        },
        "status": {
          "enum": [
            "completed",
            "failed"
          ],
          "title": "Status",
          "type": "string"
        },
        "retrieved_source_document_ids": {
          "items": {
            "type": "string"
          },
          "title": "Retrieved Source Document Ids",
          "type": "array"
        },
        "actual_behavior": {
          "anyOf": [
            {
              "$ref": "#/$defs/ExpectedBehavior"
            },
            {
              "type": "null"
            }
          ]
        },
        "source_recall": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Recall"
        },
        "source_full_hit": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "title": "Source Full Hit"
        },
        "behavior_correct": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "title": "Behavior Correct"
        },
        "expected_key_fact_count": {
          "minimum": 0,
          "title": "Expected Key Fact Count",
          "type": "integer"
        },
        "matched_key_fact_count": {
          "minimum": 0,
          "title": "Matched Key Fact Count",
          "type": "integer"
        },
        "key_fact_coverage": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Key Fact Coverage"
        },
        "retrieval_latency_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Retrieval Latency Ms"
        },
        "answer_latency_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Answer Latency Ms"
        },
        "total_latency_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total Latency Ms"
        },
        "usage": {
          "anyOf": [
            {
              "$ref": "#/$defs/BaselineTokenUsage"
            },
            {
              "type": "null"
            }
          ]
        },
        "error_stage": {
          "anyOf": [
            {
              "enum": [
                "retrieval",
                "answer"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Error Stage"
        },
        "error_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Error Type"
        }
      },
      "required": [
        "case_id",
        "category",
        "expected_behavior",
        "status",
        "retrieved_source_document_ids",
        "actual_behavior",
        "source_full_hit",
        "behavior_correct",
        "expected_key_fact_count",
        "matched_key_fact_count",
        "usage",
        "error_stage",
        "error_type"
      ],
      "title": "BaselineCaseResult",
      "type": "object"
    },
    "BaselineMetrics": {
      "additionalProperties": false,
      "properties": {
        "case_count": {
          "minimum": 0,
          "title": "Case Count",
          "type": "integer"
        },
        "completed_case_count": {
          "minimum": 0,
          "title": "Completed Case Count",
          "type": "integer"
        },
        "failed_case_count": {
          "minimum": 0,
          "title": "Failed Case Count",
          "type": "integer"
        },
        "source_scored_case_count": {
          "minimum": 0,
          "title": "Source Scored Case Count",
          "type": "integer"
        },
        "mean_source_recall": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mean Source Recall"
        },
        "full_source_hit_rate": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Full Source Hit Rate"
        },
        "behavior_scored_case_count": {
          "minimum": 0,
          "title": "Behavior Scored Case Count",
          "type": "integer"
        },
        "behavior_accuracy": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Behavior Accuracy"
        },
        "refusal_scored_case_count": {
          "minimum": 0,
          "title": "Refusal Scored Case Count",
          "type": "integer"
        },
        "refusal_accuracy": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Refusal Accuracy"
        },
        "key_fact_scored_case_count": {
          "minimum": 0,
          "title": "Key Fact Scored Case Count",
          "type": "integer"
        },
        "mean_key_fact_coverage": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mean Key Fact Coverage"
        },
        "retrieval_observed_case_count": {
          "minimum": 0,
          "title": "Retrieval Observed Case Count",
          "type": "integer"
        },
        "mean_retrieval_latency_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mean Retrieval Latency Ms"
        },
        "answer_observed_case_count": {
          "minimum": 0,
          "title": "Answer Observed Case Count",
          "type": "integer"
        },
        "mean_answer_latency_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mean Answer Latency Ms"
        },
        "usage_reported_case_count": {
          "minimum": 0,
          "title": "Usage Reported Case Count",
          "type": "integer"
        },
        "usage_missing_case_count": {
          "minimum": 0,
          "title": "Usage Missing Case Count",
          "type": "integer"
        },
        "total_input_tokens": {
          "minimum": 0,
          "title": "Total Input Tokens",
          "type": "integer"
        },
        "total_output_tokens": {
          "minimum": 0,
          "title": "Total Output Tokens",
          "type": "integer"
        },
        "total_tokens": {
          "minimum": 0,
          "title": "Total Tokens",
          "type": "integer"
        },
        "estimated_cost_cny": {
          "minimum": 0,
          "title": "Estimated Cost Cny",
          "type": "number"
        },
        "estimated_cost_complete": {
          "title": "Estimated Cost Complete",
          "type": "boolean"
        }
      },
      "required": [
        "case_count",
        "completed_case_count",
        "failed_case_count",
        "source_scored_case_count",
        "behavior_scored_case_count",
        "refusal_scored_case_count",
        "key_fact_scored_case_count",
        "retrieval_observed_case_count",
        "answer_observed_case_count",
        "usage_reported_case_count",
        "usage_missing_case_count",
        "total_input_tokens",
        "total_output_tokens",
        "total_tokens",
        "estimated_cost_cny",
        "estimated_cost_complete"
      ],
      "title": "BaselineMetrics",
      "type": "object"
    },
    "BaselineReport": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "baseline_report_v1",
          "title": "Schema Version",
          "type": "string"
        },
        "report_version": {
          "pattern": "^[a-z0-9_]+_v[0-9]+$",
          "title": "Report Version",
          "type": "string"
        },
        "run_kind": {
          "enum": [
            "fake_dry_run",
            "current_baseline",
            "candidate_comparison"
          ],
          "title": "Run Kind",
          "type": "string"
        },
        "runner_version": {
          "const": "baseline_runner_v1",
          "title": "Runner Version",
          "type": "string"
        },
        "generated_at": {
          "format": "date-time",
          "title": "Generated At",
          "type": "string"
        },
        "dataset_version": {
          "title": "Dataset Version",
          "type": "string"
        },
        "evaluation_checksum": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Evaluation Checksum",
          "type": "string"
        },
        "corpus_version": {
          "title": "Corpus Version",
          "type": "string"
        },
        "corpus_checksum": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Corpus Checksum",
          "type": "string"
        },
        "retrieval_adapter": {
          "minLength": 1,
          "title": "Retrieval Adapter",
          "type": "string"
        },
        "answer_adapter": {
          "minLength": 1,
          "title": "Answer Adapter",
          "type": "string"
        },
        "scoring_methods": {
          "$ref": "#/$defs/BaselineScoringMethods"
        },
        "metrics": {
          "$ref": "#/$defs/BaselineMetrics"
        },
        "cases": {
          "items": {
            "$ref": "#/$defs/BaselineCaseResult"
          },
          "title": "Cases",
          "type": "array"
        }
      },
      "required": [
        "schema_version",
        "report_version",
        "run_kind",
        "runner_version",
        "generated_at",
        "dataset_version",
        "evaluation_checksum",
        "corpus_version",
        "corpus_checksum",
        "retrieval_adapter",
        "answer_adapter",
        "scoring_methods",
        "metrics",
        "cases"
      ],
      "title": "BaselineReport",
      "type": "object"
    },
    "BaselineScoringMethods": {
      "additionalProperties": false,
      "properties": {
        "source_recall": {
          "const": "expected_document_id_recall_v1",
          "title": "Source Recall",
          "type": "string"
        },
        "behavior": {
          "const": "expected_behavior_exact_match_v1",
          "title": "Behavior",
          "type": "string"
        },
        "key_fact": {
          "const": "normalized_exact_substring_v1",
          "title": "Key Fact",
          "type": "string"
        }
      },
      "required": [
        "source_recall",
        "behavior",
        "key_fact"
      ],
      "title": "BaselineScoringMethods",
      "type": "object"
    },
    "BaselineTokenUsage": {
      "additionalProperties": false,
      "properties": {
        "input_tokens": {
          "minimum": 0,
          "title": "Input Tokens",
          "type": "integer"
        },
        "output_tokens": {
          "minimum": 0,
          "title": "Output Tokens",
          "type": "integer"
        },
        "total_tokens": {
          "minimum": 0,
          "title": "Total Tokens",
          "type": "integer"
        },
        "estimated_cost_cny": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Estimated Cost Cny"
        }
      },
      "required": [
        "input_tokens",
        "output_tokens",
        "total_tokens"
      ],
      "title": "BaselineTokenUsage",
      "type": "object"
    },
    "CandidateAnswerConfiguration": {
      "additionalProperties": false,
      "properties": {
        "adapter": {
          "title": "Adapter",
          "type": "string"
        },
        "model": {
          "title": "Model",
          "type": "string"
        },
        "prompt_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Prompt Sha256",
          "type": "string"
        },
        "max_output_tokens": {
          "exclusiveMinimum": 0,
          "title": "Max Output Tokens",
          "type": "integer"
        }
      },
      "required": [
        "adapter",
        "model",
        "prompt_sha256",
        "max_output_tokens"
      ],
      "title": "CandidateAnswerConfiguration",
      "type": "object"
    },
    "CandidateComparisonResult": {
      "additionalProperties": false,
      "properties": {
        "profile": {
          "$ref": "#/$defs/CandidateProfile"
        },
        "evaluation_report": {
          "$ref": "#/$defs/BaselineReport"
        },
        "stage_metrics": {
          "$ref": "#/$defs/CandidateStageMetrics"
        }
      },
      "required": [
        "profile",
        "evaluation_report",
        "stage_metrics"
      ],
      "title": "CandidateComparisonResult",
      "type": "object"
    },
    "CandidateProfile": {
      "additionalProperties": false,
      "properties": {
        "candidate_id": {
          "pattern": "^[a-z0-9_]+_v[0-9]+$",
          "title": "Candidate Id",
          "type": "string"
        },
        "display_name": {
          "maxLength": 100,
          "minLength": 1,
          "title": "Display Name",
          "type": "string"
        },
        "configuration": {
          "$ref": "#/$defs/CandidateTechnicalConfiguration"
        },
        "configuration_fingerprint": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Configuration Fingerprint",
          "type": "string"
        }
      },
      "required": [
        "candidate_id",
        "display_name",
        "configuration",
        "configuration_fingerprint"
      ],
      "title": "CandidateProfile",
      "type": "object"
    },
    "CandidateRerankConfiguration": {
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "title": "Enabled",
          "type": "boolean"
        },
        "adapter": {
          "title": "Adapter",
          "type": "string"
        },
        "model": {
          "title": "Model",
          "type": "string"
        },
        "max_candidates": {
          "maximum": 100,
          "minimum": 1,
          "title": "Max Candidates",
          "type": "integer"
        },
        "timeout_seconds": {
          "exclusiveMinimum": 0,
          "maximum": 30,
          "title": "Timeout Seconds",
          "type": "number"
        },
        "max_input_tokens": {
          "maximum": 120000,
          "minimum": 1,
          "title": "Max Input Tokens",
          "type": "integer"
        },
        "input_price_per_million_tokens_cny": {
          "minimum": 0,
          "title": "Input Price Per Million Tokens Cny",
          "type": "number"
        },
        "max_estimated_cost_cny": {
          "minimum": 0,
          "title": "Max Estimated Cost Cny",
          "type": "number"
        }
      },
      "required": [
        "enabled",
        "adapter",
        "model",
        "max_candidates",
        "timeout_seconds",
        "max_input_tokens",
        "input_price_per_million_tokens_cny",
        "max_estimated_cost_cny"
      ],
      "title": "CandidateRerankConfiguration",
      "type": "object"
    },
    "CandidateRetrievalConfiguration": {
      "additionalProperties": false,
      "properties": {
        "query_builder_version": {
          "title": "Query Builder Version",
          "type": "string"
        },
        "vector_adapter": {
          "title": "Vector Adapter",
          "type": "string"
        },
        "embedding_model": {
          "title": "Embedding Model",
          "type": "string"
        },
        "chroma_collection": {
          "title": "Chroma Collection",
          "type": "string"
        },
        "top_k": {
          "const": 4,
          "title": "Top K",
          "type": "integer"
        },
        "minimum_relevance_score": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Minimum Relevance Score"
        },
        "metadata_filters": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Metadata Filters",
          "type": "object"
        },
        "hybrid_enabled": {
          "title": "Hybrid Enabled",
          "type": "boolean"
        },
        "keyword_adapter": {
          "title": "Keyword Adapter",
          "type": "string"
        },
        "vector_weight": {
          "maximum": 1,
          "minimum": 0,
          "title": "Vector Weight",
          "type": "number"
        },
        "keyword_weight": {
          "maximum": 1,
          "minimum": 0,
          "title": "Keyword Weight",
          "type": "number"
        },
        "rrf_k": {
          "maximum": 1000,
          "minimum": 1,
          "title": "Rrf K",
          "type": "integer"
        }
      },
      "required": [
        "query_builder_version",
        "vector_adapter",
        "embedding_model",
        "chroma_collection",
        "top_k",
        "metadata_filters",
        "hybrid_enabled",
        "keyword_adapter",
        "vector_weight",
        "keyword_weight",
        "rrf_k"
      ],
      "title": "CandidateRetrievalConfiguration",
      "type": "object"
    },
    "CandidateStageMetrics": {
      "additionalProperties": false,
      "properties": {
        "retrieval_pipeline_observed_case_count": {
          "minimum": 0,
          "title": "Retrieval Pipeline Observed Case Count",
          "type": "integer"
        },
        "mean_retrieval_pipeline_latency_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mean Retrieval Pipeline Latency Ms"
        },
        "rerank_attempted_case_count": {
          "minimum": 0,
          "title": "Rerank Attempted Case Count",
          "type": "integer"
        },
        "rerank_external_call_count": {
          "minimum": 0,
          "title": "Rerank External Call Count",
          "type": "integer"
        },
        "rerank_succeeded_case_count": {
          "minimum": 0,
          "title": "Rerank Succeeded Case Count",
          "type": "integer"
        },
        "rerank_fallback_case_count": {
          "minimum": 0,
          "title": "Rerank Fallback Case Count",
          "type": "integer"
        },
        "rerank_observed_case_count": {
          "minimum": 0,
          "title": "Rerank Observed Case Count",
          "type": "integer"
        },
        "mean_rerank_latency_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mean Rerank Latency Ms"
        },
        "rerank_usage_reported_case_count": {
          "minimum": 0,
          "title": "Rerank Usage Reported Case Count",
          "type": "integer"
        },
        "rerank_usage_missing_case_count": {
          "minimum": 0,
          "title": "Rerank Usage Missing Case Count",
          "type": "integer"
        },
        "rerank_input_tokens": {
          "minimum": 0,
          "title": "Rerank Input Tokens",
          "type": "integer"
        },
        "rerank_estimated_cost_cny": {
          "minimum": 0,
          "title": "Rerank Estimated Cost Cny",
          "type": "number"
        },
        "rerank_estimated_cost_complete": {
          "title": "Rerank Estimated Cost Complete",
          "type": "boolean"
        },
        "embedding_tokens_reserved": {
          "minimum": 0,
          "title": "Embedding Tokens Reserved",
          "type": "integer"
        },
        "embedding_estimated_cost_cny": {
          "minimum": 0,
          "title": "Embedding Estimated Cost Cny",
          "type": "number"
        },
        "answer_observed_case_count": {
          "minimum": 0,
          "title": "Answer Observed Case Count",
          "type": "integer"
        },
        "mean_answer_latency_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mean Answer Latency Ms"
        },
        "mean_total_pipeline_latency_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mean Total Pipeline Latency Ms"
        },
        "total_tokens": {
          "minimum": 0,
          "title": "Total Tokens",
          "type": "integer"
        },
        "total_estimated_cost_cny": {
          "minimum": 0,
          "title": "Total Estimated Cost Cny",
          "type": "number"
        },
        "total_estimated_cost_complete": {
          "title": "Total Estimated Cost Complete",
          "type": "boolean"
        }
      },
      "required": [
        "retrieval_pipeline_observed_case_count",
        "rerank_attempted_case_count",
        "rerank_external_call_count",
        "rerank_succeeded_case_count",
        "rerank_fallback_case_count",
        "rerank_observed_case_count",
        "rerank_usage_reported_case_count",
        "rerank_usage_missing_case_count",
        "rerank_input_tokens",
        "rerank_estimated_cost_cny",
        "rerank_estimated_cost_complete",
        "embedding_tokens_reserved",
        "embedding_estimated_cost_cny",
        "answer_observed_case_count",
        "total_tokens",
        "total_estimated_cost_cny",
        "total_estimated_cost_complete"
      ],
      "title": "CandidateStageMetrics",
      "type": "object"
    },
    "CandidateTechnicalConfiguration": {
      "additionalProperties": false,
      "properties": {
        "profile_version": {
          "const": "rag_candidate_profile_v1",
          "title": "Profile Version",
          "type": "string"
        },
        "retrieval": {
          "$ref": "#/$defs/CandidateRetrievalConfiguration"
        },
        "rerank": {
          "$ref": "#/$defs/CandidateRerankConfiguration"
        },
        "answer": {
          "$ref": "#/$defs/CandidateAnswerConfiguration"
        }
      },
      "required": [
        "profile_version",
        "retrieval",
        "rerank",
        "answer"
      ],
      "title": "CandidateTechnicalConfiguration",
      "type": "object"
    },
    "EvaluationCategory": {
      "enum": [
        "single_document",
        "multi_document",
        "conversational_follow_up",
        "insufficient_knowledge",
        "safety_boundary"
      ],
      "title": "EvaluationCategory",
      "type": "string"
    },
    "ExpectedBehavior": {
      "enum": [
        "answer",
        "refuse"
      ],
      "title": "ExpectedBehavior",
