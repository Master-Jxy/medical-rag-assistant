# Copy this file to deploy/.env on the server. Never commit real secrets.
COMPOSE_PROJECT_NAME=medical-rag

DASHSCOPE_API_KEY=replace_with_your_dashscope_api_key
JWT_SECRET_KEY=replace_with_a_random_secret_at_least_32_characters

MYSQL_DATABASE=medical_rag
MYSQL_USER=medical_rag_user
MYSQL_PASSWORD=replace_with_a_strong_database_password
MYSQL_ROOT_PASSWORD=replace_with_a_different_strong_root_password

CHAT_MODEL_NAME=qwen3-max
EMBEDDING_MODEL_NAME=text-embedding-v4
DASHSCOPE_MAX_RETRIES=2
CHROMA_COLLECTION_NAME=agent

